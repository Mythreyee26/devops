# Copy this file to ".env" (same folder) and put your real Gemini key below.
# Get a key at https://aistudio.google.com/apikey
#
#   cp .env.example .env
#
# The agent loads .env automatically — no need to `export` in every terminal.

GOOGLE_API_KEY=your-key-here

# Optional: choose a model (default is gemini-2.5-flash if you omit this)
# GEMINI_MODEL=gemini-2.5-pro
